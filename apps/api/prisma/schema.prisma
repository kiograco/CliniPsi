generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PSYCHOLOGIST
  PATIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PsychologistApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum AppointmentModality {
  ONLINE
  IN_PERSON
}

model User {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String               @db.VarChar(120)
  email                 String               @unique @db.VarChar(255)
  passwordHash          String
  role                  UserRole             @default(PATIENT)
  status                UserStatus           @default(ACTIVE)
  emailVerifiedAt       DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  psychologistProfile   PsychologistProfile?
  approvedProfiles      PsychologistProfile[] @relation("PsychologistApprovedBy")
  patientAppointments   Appointment[]          @relation("PatientAppointments")
  canceledAppointments  Appointment[]          @relation("CanceledAppointments")

  @@index([role])
  @@index([status])
}

model PsychologistProfile {
  id                          String                       @id @default(uuid()) @db.Uuid
  userId                      String                       @unique @db.Uuid
  professionalName            String                       @db.VarChar(120)
  slug                        String                       @unique @db.VarChar(160)
  crp                         String                       @unique @db.VarChar(30)
  photoUrl                    String?                      @db.VarChar(500)
  bio                         String                       @db.Text
  consultationPrice           Decimal                      @db.Decimal(10, 2)
  consultationDurationMinutes Int
  offersOnline                Boolean                      @default(false)
  offersInPerson              Boolean                      @default(false)
  city                        String?                      @db.VarChar(120)
  state                       String?                      @db.VarChar(2)
  address                     String?                      @db.VarChar(255)
  whatsapp                    String?                      @db.VarChar(30)
  approvalStatus              PsychologistApprovalStatus   @default(PENDING)
  approvedAt                  DateTime?
  approvedById                String?                      @db.Uuid
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy                  User?                        @relation("PsychologistApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  specialties                 PsychologistSpecialty[]
  approaches                  PsychologistApproach[]
  availabilities              Availability[]
  scheduleBlocks              ScheduleBlock[]
  appointments                Appointment[]

  @@index([approvalStatus])
  @@index([city, state])
}

model Specialty {
  id             String                    @id @default(uuid()) @db.Uuid
  name           String                    @unique @db.VarChar(120)
  slug           String                    @unique @db.VarChar(160)
  active         Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  psychologists  PsychologistSpecialty[]
}

model Approach {
  id             String                    @id @default(uuid()) @db.Uuid
  name           String                    @unique @db.VarChar(120)
  slug           String                    @unique @db.VarChar(160)
  active         Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  psychologists  PsychologistApproach[]
}

model PsychologistSpecialty {
  psychologistId String               @db.Uuid
  specialtyId    String               @db.Uuid
  psychologist   PsychologistProfile  @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  specialty      Specialty            @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@id([psychologistId, specialtyId])
  @@index([specialtyId])
}

model PsychologistApproach {
  psychologistId String               @db.Uuid
  approachId     String               @db.Uuid
  psychologist   PsychologistProfile  @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  approach       Approach             @relation(fields: [approachId], references: [id], onDelete: Restrict)

  @@id([psychologistId, approachId])
  @@index([approachId])
}

model Availability {
  id             String              @id @default(uuid()) @db.Uuid
  psychologistId String              @db.Uuid
  weekday        Int
  startMinute    Int
  endMinute      Int
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  psychologist   PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId, weekday])
}

model ScheduleBlock {
  id             String              @id @default(uuid()) @db.Uuid
  psychologistId String              @db.Uuid
  startAt        DateTime
  endAt          DateTime
  reason         String?             @db.VarChar(255)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  psychologist   PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId, startAt, endAt])
}

model Appointment {
  id                 String              @id @default(uuid()) @db.Uuid
  psychologistId     String              @db.Uuid
  patientId          String              @db.Uuid
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus   @default(PENDING)
  modality           AppointmentModality
  cancellationReason String?             @db.VarChar(255)
  canceledById       String?             @db.Uuid
  canceledAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  psychologist       PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Restrict)
  patient            User                @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Restrict)
  canceledBy         User?               @relation("CanceledAppointments", fields: [canceledById], references: [id], onDelete: SetNull)

  @@index([psychologistId, startAt, endAt])
  @@index([patientId, startAt])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
